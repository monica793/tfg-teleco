{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Fase 3 Multiclase (Colab)\n",
        "\n",
        "Notebook limpio para ejecutar los 3 casos (energia, iq, iq_energia) con k configurable y guardar resumen CSV."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "%cd /content/tfg-teleco\n",
        "!git pull\n",
        "!pip -q install lightning wandb"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "REPS = ['energia', 'iq', 'iq_energia']\n",
        "K_C1 = 2\n",
        "K_C2 = 12\n",
        "N_TRAIN = 200\n",
        "N_VAL = 50\n",
        "SEED = 123\n",
        "EPOCHS = 80\n",
        "print(REPS, K_C1, K_C2)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 1) Generar datasets para las 3 representaciones\n",
        "for rep in REPS:\n",
        "    data_dir = f'data/fase3_{rep}_multiclase_k{K_C1}_{K_C2}'\n",
        "    cmd = f\"python -m ml.generar_dataset --representacion {rep} --modo_label multiclase_onset --k_c1 {K_C1} --k_c2 {K_C2} --n_train {N_TRAIN} --n_val {N_VAL} --semilla {SEED} --salida {data_dir}\"\n",
        "    print('\\n[RUN]', cmd)\n",
        "    !{cmd}"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 2) Entrenar los 3 modelos multiclase\n",
        "for rep in REPS:\n",
        "    data_dir = f'data/fase3_{rep}_multiclase_k{K_C1}_{K_C2}'\n",
        "    cmd = f\"python -m ml.entrenar_modelo --datos {data_dir} --representacion {rep} --modo_label multiclase_onset --num_clases 3 --epochs {EPOCHS} --batch 512 --lr 1e-3 --dropout 0.3 --workers 2 --sin_wandb\"\n",
        "    print('\\n[RUN]', cmd)\n",
        "    !{cmd}"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 3) Listar checkpoints y rellenar diccionario manualmente\n",
        "!ls -lh checkpoints | tail -n 40"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 4) Evaluación automática de los 3 checkpoints\n",
        "# Rellena rutas reales despues de entrenar\n",
        "CHECKPOINTS = {\n",
        "    'energia': 'checkpoints/REEMPLAZA_ENERGIA.ckpt',\n",
        "    'iq': 'checkpoints/REEMPLAZA_IQ.ckpt',\n",
        "    'iq_energia': 'checkpoints/REEMPLAZA_IQ_ENERGIA.ckpt',\n",
        "}\n",
        "\n",
        "import os\n",
        "import csv\n",
        "import numpy as np\n",
        "import torch\n",
        "from ml.modelo_fase1 import cargar_checkpoint\n",
        "from pipeline.escenario_phy import generar_escenario_phy, ejecutar_receptor_neuronal\n",
        "from ml.evaluar import tabla_metricas, etiquetas_multiclase_por_onset, matriz_confusion_multiclase\n",
        "from pipeline.protocolo_evaluacion import NUM_BITS_PRE, NUM_BITS_DATOS, TOLERANCIA_MUESTRAS\n",
        "\n",
        "esc = generar_escenario_phy(carga_G=0.4, ventana_frame_times=300, snr_db=6.0,\n",
        "                          num_bits_pre=NUM_BITS_PRE, num_bits_datos=NUM_BITS_DATOS,\n",
        "                          semilla=SEED, usar_preambulo=False)\n",
        "\n",
        "rows = []\n",
        "for rep, ckpt in CHECKPOINTS.items():\n",
        "    if not os.path.exists(ckpt):\n",
        "        print(f'[SKIP] {rep}: checkpoint no encontrado -> {ckpt}')\n",
        "        continue\n",
        "    device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
        "    model = cargar_checkpoint(ckpt, map_location=device)\n",
        "    sal = ejecutar_receptor_neuronal(escenario=esc, modelo=model, umbral=0.5, temperature=1.0,\n",
        "                                  dispositivo=device, stride=1, long_ventana=128, devolver_clases=True)\n",
        "    score_c1 = np.asarray(sal['score_por_muestra'], dtype=float)\n",
        "    pred_cls = np.asarray(sal['class_por_muestra'], dtype=np.int64)\n",
        "    met = tabla_metricas(score_c1, esc['instantes_llegada_muestras'], TOLERANCIA_MUESTRAS)\n",
        "    y_true = etiquetas_multiclase_por_onset(len(score_c1), esc['instantes_llegada_muestras'], K_C1, K_C2)\n",
        "    cm = matriz_confusion_multiclase(y_true, pred_cls, 3)\n",
        "\n",
        "    print(f'\\n[{rep}] PR-AUC={met[\'pr_auc\']:.4f} ROC-AUC={met[\'roc_auc\']:.4f} F1={met[\'f1_best\']:.4f} tau={met[\'tau_best\']:.2f}')\n",
        "    print(f'    TP={met[\'tp\']} FP={met[\'fp\']} FN={met[\'fn\']}')\n",
        "    print('    CM=')\n",
        "    print(cm)\n",
        "\n",
        "    rows.append({\n",
        "        'rep': rep, 'checkpoint': ckpt,\n",
        "        'pr_auc': met['pr_auc'], 'roc_auc': met['roc_auc'],\n",
        "        'f1_best': met['f1_best'], 'tau_best': met['tau_best'],\n",
        "        'tp': met['tp'], 'fp': met['fp'], 'fn': met['fn'],\n",
        "        'cm_00': int(cm[0,0]), 'cm_01': int(cm[0,1]), 'cm_02': int(cm[0,2]),\n",
        "        'cm_10': int(cm[1,0]), 'cm_11': int(cm[1,1]), 'cm_12': int(cm[1,2]),\n",
        "        'cm_20': int(cm[2,0]), 'cm_21': int(cm[2,1]), 'cm_22': int(cm[2,2]),\n",
        "    })\n",
        "\n",
        "os.makedirs('results', exist_ok=True)\n",
        "csv_path = f'results/fase3_multiclase_resumen_k{K_C1}_{K_C2}.csv'\n",
        "if rows:\n",
        "    with open(csv_path, 'w', newline='') as f:\n",
        "        w = csv.DictWriter(f, fieldnames=list(rows[0].keys()))\n",
        "        w.writeheader()\n",
        "        w.writerows(rows)\n",
        "    print('\\nCSV guardado:', csv_path)\n",
        "else:\n",
        "    print('No se guardó CSV (sin filas válidas).')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# 5) Auditoría C2 por representación\n",
        "import numpy as np\n",
        "for rep in REPS:\n",
        "    dpath = f'data/fase3_{rep}_multiclase_k{K_C1}_{K_C2}'\n",
        "    Dp = f'{dpath}/D_train.npy'\n",
        "    Yp = f'{dpath}/Y_train.npy'\n",
        "    if not (os.path.exists(Dp) and os.path.exists(Yp)):\n",
        "        print(f'[SKIP] {rep}: no D/Y')\n",
        "        continue\n",
        "    D = np.load(Dp)\n",
        "    Y = np.load(Yp)\n",
        "    c2 = D[Y == 2]\n",
        "    print(f'[{rep}] C2 |d| n={len(c2)}')\n",
        "    if len(c2) > 0:\n",
        "        print('  min=', np.min(c2), 'p25=', np.percentile(c2,25), 'p50=', np.percentile(c2,50),\n",
        "              'p75=', np.percentile(c2,75), 'max=', np.max(c2))"
      ]
    }
  ],
